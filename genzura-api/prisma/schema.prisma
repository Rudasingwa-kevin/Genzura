generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  Admin
  Senior_Attorney
  Attorney
  Paralegal
  Support
}

enum UserStatus {
  Active
  Invited
  Suspended
}

enum SubscriptionPlan {
  Genzura   // Free tier
  Intango   // 100,000 RWF / 3 months
  Inkingi   // 200,000 RWF / 12 months
}

enum CaseStatus {
  Active
  Pending
  Resolved
  Archived
}

enum CasePriority {
  High
  Medium
  Low
}

enum CaseType {
  Litigation
  Corporate
  Compliance
  IP
  Employment
  MA
  Real_Estate
}

enum TimelineEventType {
  filed
  status
  meeting
  document
  note
  milestone
}

enum DocumentType {
  PDF
  DOCX
  XLSX
  IMG
}

enum FeedbackStatus {
  Pending
  Reviewed
  In_Progress
  Resolved
}

enum NotificationType {
  case
  deadline
  document
  alert
  resolved
}

model User {
  id                    String           @id @default(cuid())
  name                  String
  email                 String           @unique
  passwordHash          String
  role                  UserRole         @default(Attorney)
  status                UserStatus       @default(Active)
  lastActive            DateTime         @default(now())
  initials              String
  // Profile fields
  phone                 String?
  location              String?
  jobTitle              String?
  language              String?          @default("EN")
  // Subscription fields
  subscriptionPlan      SubscriptionPlan @default(Genzura)
  subscriptionStartDate DateTime?
  subscriptionEndDate   DateTime?
  // Relations
  cases                 Case[]           @relation("AttorneyCases")
  teamMemberships       CaseTeam[]
  timelineEvents        TimelineEvent[]
  uploadedDocs          CaseDocument[]
  notes                 CaseNote[]
  feedback              Feedback[]
  notifications         Notification[]
  calendarEvents        CalendarEvent[]
  eventAttendees        EventAttendee[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
}

model Client {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  phone        String?
  company      String?
  industry     String?
  address      String?
  idNumber     String?    // National ID or TIN
  cases        Case[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Case {
  id            String          @id @default(cuid())
  caseNumber    String          @unique
  title         String
  client        Client          @relation(fields: [clientId], references: [id])
  clientId      String
  attorney      User            @relation("AttorneyCases", fields: [attorneyId], references: [id])
  attorneyId    String
  status        CaseStatus      @default(Pending)
  priority      CasePriority    @default(Medium)
  type          CaseType
  deadline      DateTime?
  filedDate     DateTime        @default(now())
  description   String          @db.Text
  team          CaseTeam[]
  timeline      TimelineEvent[]
  documents     CaseDocument[]
  notes         CaseNote[]
  events        CalendarEvent[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model CaseTeam {
  id      String @id @default(cuid())
  case    Case   @relation(fields: [caseId], references: [id])
  caseId  String
  user    User   @relation(fields: [userId], references: [id])
  userId  String
  role    String // Specific role in this case

  @@unique([caseId, userId])
}

model TimelineEvent {
  id          String            @id @default(cuid())
  case        Case              @relation(fields: [caseId], references: [id])
  caseId      String
  type        TimelineEventType
  description String
  author      User              @relation(fields: [authorId], references: [id])
  authorId    String
  timestamp   DateTime          @default(now())
}

model CaseDocument {
  id           String       @id @default(cuid())
  case         Case         @relation(fields: [caseId], references: [id])
  caseId       String
  name         String
  type         DocumentType
  size         String
  fileUrl      String?
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])
  uploadedById String
  uploadedAt   DateTime     @default(now())
}

model CaseNote {
  id        String   @id @default(cuid())
  case      Case     @relation(fields: [caseId], references: [id])
  caseId    String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  text      String   @db.Text
  timestamp DateTime @default(now())
}

model Feedback {
  id        String         @id @default(cuid())
  user      User           @relation(fields: [userId], references: [id])
  userId    String
  subject   String
  category  String
  message   String         @db.Text
  status    FeedbackStatus @default(Pending)
  createdAt DateTime       @default(now())
}

model Notification {
  id        String           @id @default(cuid())
  user      User             @relation(fields: [userId], references: [id])
  userId    String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())
}

model SystemSetting {
  key       String   @id
  value     String   @db.Text
  category  String
  updatedAt DateTime @updatedAt
}

enum CalendarEventType {
  CourtDate
  Hearing
  Filing
  Deadline
  Meeting
  ClientMeeting
  Consultation
  Other
}

model CalendarEvent {
  id          String            @id @default(cuid())
  title       String
  description String?           @db.Text
  eventType   CalendarEventType
  startDate   DateTime
  endDate     DateTime?
  location    String?
  caseId      String?
  case        Case?             @relation(fields: [caseId], references: [id], onDelete: Cascade)
  attendees   EventAttendee[]
  reminders   EventReminder[]
  createdBy   User              @relation(fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model EventAttendee {
  id      String        @id @default(cuid())
  event   CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId String
  user    User          @relation(fields: [userId], references: [id])
  userId  String

  @@unique([eventId, userId])
}

enum ReminderMethod {
  Email
  SMS
  InApp
}

model EventReminder {
  id             String          @id @default(cuid())
  event          CalendarEvent   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId        String
  reminderTime   DateTime
  method         ReminderMethod
  sent           Boolean         @default(false)
  sentAt         DateTime?
  createdAt      DateTime        @default(now())
}

model PlanConfig {
  id              String           @id @default(cuid())
  plan            SubscriptionPlan @unique

  // Pricing
  price           Int              // Price in RWF
  duration        Int              // Duration in days

  // Display
  displayName     String           // e.g., "Intango"
  tagline         String?          // e.g., "Most Popular"
  description     String?

  // Limits
  maxCases        Int?             // null = unlimited
  maxDocuments    Int?             // null = unlimited
  maxTeamMembers  Int?             // null = unlimited
  storageGB       Int?

  // Features (JSON)
  features        Json             // Flexible feature flags

  // Status
  isActive        Boolean          @default(true)
  isVisible       Boolean          @default(true) // Show on pricing page

  // Audit
  lastModifiedBy  String?
  lastModifiedAt  DateTime         @default(now()) @updatedAt
  createdAt       DateTime         @default(now())
}

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/genzura_db"

# JWT Secret
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for email links)
FRONTEND_URL="http://localhost:5173"

# Brevo (Sendinblue) Email Service
# Get these from: https://app.brevo.com/settings/keys/smtp
BREVO_SMTP_USER="your-email@example.com"
BREVO_SMTP_KEY="your-brevo-smtp-key-here"

# Alternative: Use API key instead of SMTP
# BREVO_API_KEY="xkeysib-xxxxx..."
